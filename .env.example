# SMTP settings (Option A: connection URL)
# Example pooled TLS URL:
# SMTP_URL=smtps://username:password@smtp.example.com/?pool=true
# Example direct transport:
# SMTP_URL=direct:?name=hostname.example.com

# SMTP settings (Option B: host/port/auth)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Sender address shown in recipient inbox
FROM_EMAIL="Ticketmaster <no-reply@yourdomain.com>"

# Optional
PORT=3000
